generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// EXISTING: Curated directory models (Item = hand-picked edu platforms)
// ---------------------------------------------------------------------------

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  sortOrder   Int       @default(0)
  groupName   String    @default("Default")
  items       Item[]
  listings    Listing[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([groupName])
  @@index([sortOrder])
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  items       ItemTag[]
  listings    ListingTag[]
  createdAt   DateTime     @default(now())

  @@index([slug])
}

model Item {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  url         String
  description String
  content     String?
  icon        String?
  screenshot  String?
  featured    Boolean   @default(false)
  sortOrder   Int       @default(0)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  tags        ItemTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([featured])
  @@index([createdAt])
}

model ItemTag {
  itemId String
  tagId  String
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// NEW: Aggregator models (Listing = API-sourced content from providers)
// ---------------------------------------------------------------------------

model Provider {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  url           String
  logo          String?
  description   String?
  apiType         String         @default("rest") // rest | graphql | rss | scrape | manual
  apiBaseUrl      String?
  isActive        Boolean        @default(true)
  syncFrequency   String         @default("daily") // hourly | daily | weekly
  authType             String    @default("none") // none | api_key | oauth | basic | token
  rateLimitPerMinute   Int?
  syncCursor           String?
  lastSuccessfulSyncAt DateTime?
  lastFailedSyncAt     DateTime?
  failureCount         Int       @default(0)
  complianceNotes      String?
  lastSyncAt      DateTime?
  affiliateTag    String?
  commissionRate  Float?         // e.g. 0.10 = 10%
  listings        Listing[]
  offers          ListingOffer[]
  syncLogs        SyncLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum ListingType {
  course
  job
  event
  deal
}

model Listing {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  type         ListingType
  description  String
  content      String?
  url          String
  image        String?
  price        Float?
  currency     String         @default("USD")
  priceLabel   String?
  rating       Float?
  reviewCount  Int?
  duration     String?
  level        String?
  language     String         @default("en")
  location     String?
  startDate    DateTime?
  endDate      DateTime?
  expiresAt    DateTime?
  featured     Boolean        @default(false)
  verified     Boolean        @default(false)
  viewCount    Int            @default(0)
  clickCount   Int            @default(0)
  externalId   String?
  status          String    @default("active") // active | stale | expired | hidden | needs_review
  canonicalUrl    String?
  fingerprint     String?
  sourceUpdatedAt DateTime?
  publishedAt     DateTime?
  lastSeenAt      DateTime?
  qualityScore    Float     @default(0)
  companyName     String?
  salaryMin       Float?
  salaryMax       Float?
  salaryCurrency  String?
  couponCode      String?
  discountText    String?
  venueName       String?
  country         String?
  region          String?
  metadata        Json?
  compliance      Json?
  providerId   String
  provider     Provider       @relation(fields: [providerId], references: [id])
  categoryId   String?
  category     Category?      @relation(fields: [categoryId], references: [id])
  offers       ListingOffer[]
  tags         ListingTag[]
  savedBy      SavedListing[]
  clicks       ClickEvent[]
  sponsored    SponsoredListing[]
  applications Application[]
  priceHistory PriceHistory[]
  reviews      Review[]
  learningProgress LearningProgress[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([providerId, externalId])
  @@index([type])
  @@index([categoryId])
  @@index([featured])
  @@index([createdAt])
  @@index([price])
  @@index([rating])
  @@index([status])
  @@index([lastSeenAt])
  @@index([expiresAt])
  @@index([fingerprint])
  @@index([sourceUpdatedAt])
}

model ListingOffer {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  url          String
  affiliateUrl String?
  price        Float?
  currency     String   @default("USD")
  priceLabel   String?
  isAvailable  Boolean  @default(true)
  lastChecked  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([listingId, providerId])
  @@index([providerId])
}

model ListingTag {
  listingId String
  tagId     String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
  @@index([tagId])
}

model Deal {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  code        String?
  url         String
  discount    String?
  image       String?
  providerName String?
  categorySlug String?
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// NEW: User & personalization models
// ---------------------------------------------------------------------------

model AppUser {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  avatar        String?
  role            String         @default("user") // user | pro | admin
  tier            String         @default("free") // free | pro
  proExpiresAt    DateTime?
  emailVerified   Boolean        @default(false)
  banned          Boolean        @default(false)
  bannedAt        DateTime?
  bannedReason    String?
  stripeCustomerId String?      @unique
  profile         UserProfile?
  savedSearches   SavedSearch[]
  savedListings   SavedListing[]
  clicks          ClickEvent[]
  applications    Application[]
  notifications   Notification[]
  reviews         Review[]
  replies         Reply[]
  reviewVotes     ReviewVote[]
  reports         Report[]
  subscriptions   Subscription[]
  following       Follow[]       @relation("UserFollowing")
  followers       Follow[]       @relation("UserFollowers")
  activities      UserActivity[]
  badges          UserBadge[]
  learningProgress LearningProgress[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  educationLevel String?
  interests      String[]
  preferredLang    String   @default("en")
  notifyNewMatch   Boolean  @default(true)
  notifyPriceDrop  Boolean  @default(true)
  notifyNewsletter Boolean  @default(true)
  resumeUrl        String?
  headline         String?
  skills         String[]
  experience     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SavedSearch {
  id           String    @id @default(cuid())
  userId       String
  user         AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  query        String?
  filters      Json
  alertEnabled Boolean   @default(false)
  lastAlertAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// NEW: Analytics & sync tracking
// ---------------------------------------------------------------------------

model SyncLog {
  id           String    @id @default(cuid())
  providerId   String
  provider     Provider  @relation(fields: [providerId], references: [id])
  status       String    // running | success | error
  itemsFound   Int       @default(0)
  itemsAdded   Int       @default(0)
  itemsUpdated Int       @default(0)
  itemsSkipped Int     @default(0)
  itemsExpired Int     @default(0)
  durationMs   Int?
  details      Json?
  error        String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([providerId])
  @@index([startedAt])
}

model ClickEvent {
  id           String   @id @default(cuid())
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId       String?
  user         AppUser? @relation(fields: [userId], references: [id])
  providerId   String?
  offerId      String?
  affiliateTag String?
  commission   Float?
  referrer     String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([listingId])
  @@index([userId])
  @@index([createdAt])
  @@index([affiliateTag])
}

// ---------------------------------------------------------------------------
// NEW Phase 4: Sponsored listings & Applications
// ---------------------------------------------------------------------------

model SponsoredListing {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  position    String   // hero | feed | sidebar
  label       String   @default("Sponsored")
  budget      Float    @default(0)
  spent       Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  cpc         Float?   // cost per click
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([position, isActive])
  @@index([startDate])
  @@index([endDate])
}

enum ApplicationStatus {
  draft
  applied
  viewed
  interview
  offered
  rejected
  withdrawn
}

model Application {
  id         String            @id @default(cuid())
  userId     String
  user       AppUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  status     ApplicationStatus @default(applied)
  coverNote  String?
  resumeUrl  String?
  appliedAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Phase 6: Email verification, password reset, notifications
// ---------------------------------------------------------------------------

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // new_match | price_drop | system | welcome
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price     Float
  currency  String   @default("USD")
  recordedAt DateTime @default(now())

  @@index([listingId])
  @@index([recordedAt])
}

// ---------------------------------------------------------------------------
// Phase 7: Reviews & Social
// ---------------------------------------------------------------------------

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  title     String?
  body      String?
  helpful   Int      @default(0)
  replies   Reply[]
  votes     ReviewVote[]
  reports   Report[]   @relation("ReviewReports")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([userId])
  @@index([rating])
}

// ---------------------------------------------------------------------------
// Phase 16: Community — Replies, Votes, Reports
// ---------------------------------------------------------------------------

model Reply {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Reply?   @relation("ReplyThread", fields: [parentId], references: [id], onDelete: Cascade)
  children  Reply[]  @relation("ReplyThread")
  body      String
  reports   Report[] @relation("ReplyReports")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId])
  @@index([userId])
  @@index([parentId])
}

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int      // 1 = upvote, -1 = downvote
  createdAt DateTime @default(now())

  @@unique([userId, reviewId])
  @@index([reviewId])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId  String?
  review    Review?  @relation("ReviewReports", fields: [reviewId], references: [id], onDelete: Cascade)
  replyId   String?
  reply     Reply?   @relation("ReplyReports", fields: [replyId], references: [id], onDelete: Cascade)
  reason    String   // spam | harassment | misinformation | other
  details   String?
  status    String   @default("pending") // pending | reviewed | dismissed
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([reviewId])
  @@index([replyId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Phase 15: Stripe subscriptions
// ---------------------------------------------------------------------------

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  user                 AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String    @unique
  stripePriceId        String
  status               String    // active | past_due | canceled | trialing | incomplete
  plan                 String    // pro_monthly | pro_yearly
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Phase 12: Admin audit log
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actor     String   // admin email or "system"
  action    String   // e.g. "user.ban", "review.delete", "listing.approve"
  target    String?  // target entity id
  details   Json?    // extra context
  createdAt DateTime @default(now())

  @@index([actor])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Phase 22: Social — Follow, Activity Feed, Badges, Learning Progress
// ---------------------------------------------------------------------------

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    AppUser  @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   AppUser  @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // review | reply | save | follow | badge | enroll | complete
  message   String
  link      String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     String   // badge slug: first_review, five_reviews, first_save, explorer, etc.
  awardedAt DateTime @default(now())

  @@unique([userId, badge])
  @@index([userId])
}

model LearningProgress {
  id          String   @id @default(cuid())
  userId      String
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  status      String   @default("enrolled") // enrolled | in_progress | completed | dropped
  progress    Int      @default(0) // 0-100 percentage
  startedAt   DateTime @default(now())
  completedAt DateTime?
  notes       String?
  updatedAt   DateTime @updatedAt

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([status])
}
