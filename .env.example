# =============================================================================
# EDU Passport Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fxxknav"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-a-random-secret-here"   # openssl rand -base64 32
NEXTAUTH_URL="https://edupassport.me"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://edupassport.me"
NEXT_PUBLIC_SITE_NAME="EDU Passport"

# --- Admin ---
ADMIN_PASSWORD="change-me-in-production"

# --- Cron ---
CRON_SECRET="generate-a-random-secret-here"

# --- Provider API Keys ---
UDEMY_API_KEY=""

# --- SMTP (leave SMTP_HOST empty for dev console logger) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@edupassport.me"

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- OpenAI (AI features) ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Logging ---
LOG_LEVEL="info"   # debug | info | warn | error

# --- Docker Compose (only needed for docker-compose.yml) ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="fxxknav"
POSTGRES_PORT="5432"
APP_PORT="3000"
