# =============================================================================
# EDU Passport Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fxxknav"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-a-random-secret-here"   # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="EDU Passport"

# --- Admin ---
ADMIN_PASSWORD="change-me-in-production"

# --- Cron ---
CRON_SECRET="generate-a-random-secret-here"

# --- Provider API Keys ---
UDEMY_API_KEY=""

# --- SMTP (recommended production provider: Resend) ---
# Local/dev: leave SMTP_HOST empty to use console JSON email output.
# Resend production values:
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="resend"
# SMTP_PASS="re_xxx"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@edupassport.me"

# --- Stripe (optional future payments; leave blank for manual Pro activation) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- OpenAI (AI features) ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Logging ---
LOG_LEVEL="info"   # debug | info | warn | error

# --- Docker Compose (only needed for docker-compose.yml) ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="fxxknav"
POSTGRES_PORT="5432"
APP_PORT="3000"
