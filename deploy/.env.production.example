# Image produced by GitHub Actions. The workflow writes this automatically.
APP_IMAGE="ghcr.io/unilei/edupassportme:sha-REPLACE_ME"

# Server port exposed by Docker Compose.
APP_PORT="3000"

# Internal PostgreSQL container.
POSTGRES_USER="edupassport"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="edupassport"
DATABASE_URL="postgresql://edupassport:change-me@postgres:5432/edupassport"

# App runtime.
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="https://edupassport.me"
NEXT_PUBLIC_SITE_URL="https://edupassport.me"
NEXT_PUBLIC_SITE_NAME="EDU Passport"
ADMIN_PASSWORD="change-me"
CRON_SECRET="change-me"

# GHCR pull credentials are injected by GitHub Actions from the built-in
# workflow token and are removed from the compose .env after docker login.

# Optional credentialed providers and integrations. Public no-account providers
# such as Microsoft Learn, MIT OCW, GitHub Student Pack, and Slickdeals
# Education do not need env vars.
UDEMY_API_KEY=""
USAJOBS_API_KEY=""
USAJOBS_USER_AGENT=""
TICKETMASTER_API_KEY=""
AWIN_ACCESS_TOKEN=""
AWIN_PUBLISHER_ID=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@edupassport.me"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
LOG_LEVEL="info"
